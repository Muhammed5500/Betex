# Copy to .env.local after running `npm run deploy:monad` (or deploy:local).
# All addresses below are public (contract addresses, chain id, RPC URL) —
# safe to commit the filled-in .env.local if that fits your workflow.

NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz

NEXT_PUBLIC_ENCRYPTED_POOL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SEALED_AMM_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BTX_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SCHNORR_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_MON_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — WalletConnect v2 cloud project id. RainbowKit falls back to
# injected-only connectors if this is unset.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
